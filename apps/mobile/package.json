{
  "name": "@karakeep/mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "clean": "git clean -xdf .expo .turbo node_modules",
    "clean:prebuild": "APP_VARIANT=development expo prebuild --no-install --clean",
    "start": "expo start",
    "android": "APP_VARIANT=development expo run:android",
    "android:preview": "SENTRY_DISABLE_AUTO_UPLOAD=true APP_VARIANT=development pnpm run android --variant release",
    "android:release": "SENTRY_DISABLE_AUTO_UPLOAD=true pnpm run android --variant release",
    "ios": "APP_VARIANT=development expo run:ios",
    "ios:preview": "SENTRY_DISABLE_AUTO_UPLOAD=true APP_VARIANT=development pnpm run ios --configuration Release",
    "ios:release": "SENTRY_DISABLE_AUTO_UPLOAD=true pnpm run ios --configuration Release",
    "web": "expo start --web",
    "format": "oxfmt --ignore-path=../../.gitignore --ignore-path=./.gitignore --check .",
    "format:fix": "oxfmt --ignore-path=../../.gitignore --ignore-path=./.gitignore .",
    "lint": "oxlint --ignore-path=../../.gitignore .",
    "lint:fix": "oxlint --ignore-path=../../.gitignore . --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/dom-webview": "~56.0.6",
    "@expo/metro-runtime": "~56.0.16",
    "@expo/vector-icons": "^15.0.3",
    "@karakeep/shared": "workspace:^0.1.0",
    "@karakeep/shared-react": "workspace:^0.1.0",
    "@karakeep/trpc": "workspace:^0.1.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "^5.2.0",
    "@react-native-menu/menu": "^2.0.0",
    "@rn-primitives/hooks": "^1.3.0",
    "@rn-primitives/slot": "^1.2.0",
    "@sentry/react-native": "^8.14.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "5.90.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "expo": "~56.0.15",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.22",
    "expo-checkbox": "~56.0.1",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.20",
    "expo-dev-client": "~56.0.22",
    "expo-file-system": "~56.0.8",
    "expo-glass-effect": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-image-picker": "~56.0.20",
    "expo-keep-awake": "~56.0.3",
    "expo-linking": "~56.0.15",
    "expo-navigation-bar": "~56.0.3",
    "expo-router": "~56.2.14",
    "expo-secure-store": "~56.0.4",
    "expo-share-intent": "^7.0.0",
    "expo-sharing": "~56.0.21",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "lucide-react-native": "^0.513.0",
    "nativewind": "^4.2.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-native": "0.85.3",
    "react-native-blob-util": "^0.21.2",
    "react-native-css-interop": "0.2.1",
    "react-native-draggable-flatlist": "4.0.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-image-viewing": "^0.2.2",
    "react-native-keyboard-controller": "^1.21.6",
    "react-native-markdown-display": "^7.0.2",
    "react-native-pdf": "7.0.3",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "sonner-native": "^0.22.2",
    "tailwind-merge": "^2.2.1",
    "zod": "^4.0.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@karakeep/tailwind-config": "workspace:^0.1.0",
    "@karakeep/tsconfig": "workspace:^0.1.0",
    "@types/react": "19.2.15",
    "ajv": "latest",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9"
  },
  "expo": {
    "install": {
      "exclude": [
        "@sentry/react-native",
        "typescript"
      ]
    }
  },
  "private": true
}
